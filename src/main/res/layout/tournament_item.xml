<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Tournament Image -->
        <ImageView
            android:id="@+id/imgTournament"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"/>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTournamentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tournament Title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <!-- Game -->
        <TextView
            android:id="@+id/tvTournamentType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Game Name"
            android:layout_marginTop="4dp"/>

        <!-- Prize -->
        <TextView
            android:id="@+id/tvTournamentPrize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prize ₹10000"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <!-- Entry Fee -->
        <TextView
            android:id="@+id/tvEntryFee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entry ₹50"
            android:layout_marginTop="4dp"/>
        <!-- Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tournament Description"
            android:layout_marginTop="6dp"
            android:maxLines="2"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Register Tournament"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:cornerRadius="14dp"
            android:backgroundTint="@color/green"
            android:textColor="@android:color/white"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>